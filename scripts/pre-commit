#!/usr/bin/env bash
# pre-commit hook — runs check_leaks.py before each commit
# Install: cp scripts/pre-commit .git/hooks/pre-commit
# Or: ln -s ../../scripts/pre-commit .git/hooks/pre-commit

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

# Only check if we're in a git repo
if [ ! -d ".git" ]; then
    exit 0
fi

echo "[pre-commit] Running leak check..."
python scripts/check_leaks.py
echo "[pre-commit] OK"
