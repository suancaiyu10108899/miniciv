# DeepSeek API (Anthropic-compatible endpoint)
# 1. Get your key at https://platform.deepseek.com/api_keys
# 2. Copy this file to .env (which is gitignored)
# 3. Fill in your actual key below
ANTHROPIC_AUTH_TOKEN=sk-your-new-key-here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
